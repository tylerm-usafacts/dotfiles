#!/bin/zsh

set -euo pipefail

script_dir=${0:A:h}
"$script_dir/sync-ai-config"

self_path=${0:A}
versions_dir="$HOME/.local/share/claude/versions"
real_binary=""

if [[ -d "$versions_dir" ]]; then
  candidates=("$versions_dir"/*(N-.om[1]))
  if (( ${#candidates} > 0 )) && [[ -x "${candidates[1]}" ]]; then
    real_binary="${candidates[1]}"
  fi
fi

if [[ -z "$real_binary" ]]; then
  for candidate in ${(f)"$(which -a claude)"}; do
    candidate_path=${candidate:A}
    if [[ "$candidate_path" != "$self_path" ]]; then
      real_binary="$candidate"
      break
    fi
  done
fi

if [[ -z "$real_binary" ]]; then
  echo "claude wrapper: unable to find real 'claude' binary on PATH" >&2
  echo "Run: curl -fsSL https://claude.ai/install.sh | bash" >&2
  exit 1
fi

exec "$real_binary" "$@"

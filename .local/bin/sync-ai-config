#!/usr/bin/env bash

set -euo pipefail

GENERATED_MARKER='<!-- Generated by sync-ai-config. Do not edit manually. -->'

check_only=0

fail() {
  echo "sync-ai-config: $1" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage: sync-ai-config [--check]
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command '$1'"
}

read_file_if_exists() {
  local path="$1"
  if [[ -f "$path" ]]; then
    cat "$path"
  fi
}

resolve_path_for_compare() {
  local value="$1"
  local base_dir="$2"

  if [[ "$value" == /* ]]; then
    (
      cd "$(dirname "$value")" >/dev/null 2>&1 || exit 1
      printf '%s/%s\n' "$(pwd -P)" "$(basename "$value")"
    )
    return
  fi

  (
    cd "$base_dir" >/dev/null 2>&1 || exit 1
    cd "$(dirname "$value")" >/dev/null 2>&1 || exit 1
    printf '%s/%s\n' "$(pwd -P)" "$(basename "$value")"
  )
}

ensure_symlink() {
  local path="$1"
  local target="$2"

  if [[ -d "$path" && ! -L "$path" ]]; then
    fail "expected symlink at '$path' but found directory"
  fi

  local base_dir expected_resolved current_resolved
  base_dir="$(dirname "$path")"
  expected_resolved="$(resolve_path_for_compare "$target" "$base_dir")"

  if [[ -L "$path" ]]; then
    current_resolved="$(resolve_path_for_compare "$(readlink "$path")" "$base_dir")"
    if [[ "$current_resolved" == "$expected_resolved" ]]; then
      return
    fi
  fi

  changed=1
  if (( check_only )); then
    return
  fi

  mkdir -p "$(dirname "$path")"
  rm -f "$path"
  ln -s "$target" "$path"
}

ensure_text_file() {
  local path="$1"
  local expected="$2"
  local current=""

  if [[ -f "$path" ]]; then
    current="$(cat "$path")"
  fi

  if [[ "$current" == "$expected" ]]; then
    return
  fi

  changed=1
  if (( check_only )); then
    return
  fi

  mkdir -p "$(dirname "$path")"
  printf '%s' "$expected" > "$path"
}

extract_markdown_parts() {
  local source="$1"
  local frontmatter_out="$2"
  local body_out="$3"

  awk -v front="$frontmatter_out" -v body="$body_out" '
    NR == 1 {
      if ($0 != "---") {
        exit 10
      }
      in_front = 1
      next
    }

    in_front {
      if ($0 == "---") {
        in_front = 0
        in_body = 1
        front_closed = 1
        next
      }
      print >> front
      next
    }

    in_body {
      print >> body
    }

    END {
      if (!front_closed) {
        exit 11
      }
    }
  ' "$source"
}

normalize_body() {
  local source="$1"
  local destination="$2"

  awk '
    {
      lines[NR] = $0
    }
    END {
      start = 1
      while (start <= NR && lines[start] == "") start++

      finish = NR
      while (finish >= start && lines[finish] == "") finish--

      for (i = start; i <= finish; i++) {
        print lines[i]
      }
    }
  ' "$source" > "$destination"
}

render_agent_file() {
  local frontmatter_yaml="$1"
  local body_file="$2"
  local output_file="$3"

  {
    echo '---'
    cat "$frontmatter_yaml"
    echo '---'
    echo
    echo "$GENERATED_MARKER"
    if [[ -s "$body_file" ]]; then
      echo
      cat "$body_file"
    fi
    echo
  } > "$output_file"
}

build_claude_json() {
  local source_json_file="$1"

  jq -c '
    . as $source
    | (if ((has("maxTurns") | not) and has("steps")) then . + { maxTurns: .steps } else . end) as $mapped
    | reduce [
        "name",
        "description",
        "tools",
        "disallowedTools",
        "model",
        "permissionMode",
        "maxTurns",
        "skills",
        "mcpServers",
        "hooks",
        "memory",
        "background",
        "effort",
        "isolation"
      ][] as $key ({};
        if $mapped | has($key) then
          . + { ($key): $mapped[$key] }
        else
          .
        end
      )
  ' "$source_json_file"
}

build_opencode_json() {
  local source_json_file="$1"

  jq -c '
    . as $source
    | (if ((has("steps") | not) and has("maxTurns")) then . + { steps: .maxTurns } else . end) as $mapped
    | reduce [
        "description",
        "mode",
        "model",
        "temperature",
        "top_p",
        "steps",
        "disable",
        "prompt",
        "tools",
        "permission",
        "hidden",
        "color"
      ][] as $key ({};
        if $mapped | has($key) then
          . + { ($key): $mapped[$key] }
        else
          .
        end
      )
  ' "$source_json_file"
}

sync_directory() {
  local destination_dir="$1"
  local expected_dir="$2"

  if [[ ! -d "$destination_dir" ]]; then
    changed=1
    if (( check_only )); then
      return
    fi
    mkdir -p "$destination_dir"
  fi

  local expected_file
  for expected_file in "$expected_dir"/*.md; do
    [[ -e "$expected_file" ]] || break
    local base
    base="$(basename "$expected_file")"
    local destination_file="$destination_dir/$base"

    if [[ ! -f "$destination_file" ]] || ! cmp -s "$expected_file" "$destination_file"; then
      changed=1
      if (( !check_only )); then
        cp "$expected_file" "$destination_file"
      fi
    fi
  done

  local destination_file
  for destination_file in "$destination_dir"/*.md; do
    [[ -e "$destination_file" ]] || break
    local base
    base="$(basename "$destination_file")"

    if [[ -f "$expected_dir/$base" ]]; then
      continue
    fi

    if grep -Fq "$GENERATED_MARKER" "$destination_file"; then
      changed=1
      if (( !check_only )); then
        rm -f "$destination_file"
      fi
    fi
  done
}

build_opencode_mcp_json() {
  local source_json_file="$1"

  jq -c '
    .mcpServers
    | with_entries(
        .value = (
          if .value.type == "stdio" then
            {
              type: "local",
              command: (
                if (.value.command | type) == "array" then
                  .value.command
                else
                  [ .value.command ] + (.value.args // [])
                end
              )
            }
            + (if .value.env then { environment: .value.env } else {} end)
            + (if .value.enabled != null then { enabled: .value.enabled } else {} end)
            + (if .value.timeout != null then { timeout: .value.timeout } else {} end)
          elif (.value.type == "http" or .value.type == "sse") then
            {
              type: "remote",
              url: .value.url
            }
            + (if .value.enabled != null then { enabled: .value.enabled } else {} end)
            + (if .value.headers then { headers: .value.headers } else {} end)
            + (if .value.oauth != null then { oauth: .value.oauth } else {} end)
            + (if .value.timeout != null then { timeout: .value.timeout } else {} end)
          elif (.value.type == "remote" or .value.type == "local") then
            .value
          else
            .value
          end
        )
      )
  ' "$source_json_file"
}

build_claude_mcp_json() {
  local source_json_file="$1"

  jq -c '
    .mcpServers
    | with_entries(
        .value = (
          .value
          | del(.enabled)
          | if (.type == "stdio" and (.command | type) == "array") then
              {
                type: "stdio",
                command: .command[0],
                args: .command[1:]
              }
              + (if .env then { env: .env } else {} end)
            else
              .
            end
        )
      )
    | { mcpServers: . }
  ' "$source_json_file"
}

sync_mcp_configs() {
  local source_file="$1"
  local opencode_config_file="$2"
  local claude_project_mcp_file="$3"

  if [[ ! -f "$source_file" ]]; then
    return
  fi

  if ! jq -e '.mcpServers | type == "object"' "$source_file" >/dev/null 2>&1; then
    fail "$source_file: missing required object key 'mcpServers'"
  fi

  if ! jq -e '
    .mcpServers
    | to_entries
    | all(
        .[];
        (
          (.value.type == "http" or .value.type == "sse") and (.value.url | type == "string")
        )
        or
        (
          .value.type == "stdio" and
          (
            (.value.command | type == "string")
            or
            ((.value.command | type == "array") and (.value.command | length > 0))
          )
        )
      )
  ' "$source_file" >/dev/null 2>&1; then
    fail "$source_file: each server requires valid type-specific fields"
  fi

  local opencode_mcp_json
  opencode_mcp_json="$(build_opencode_mcp_json "$source_file")"

  local opencode_current_json
  opencode_current_json="$(read_file_if_exists "$opencode_config_file")"
  if [[ -z "$opencode_current_json" ]]; then
    opencode_current_json='{}'
  fi

  if ! printf '%s' "$opencode_current_json" | jq empty >/dev/null 2>&1; then
    fail "$opencode_config_file: invalid JSON"
  fi

  local opencode_expected_json
  opencode_expected_json="$(printf '%s' "$opencode_current_json" | jq --argjson mcp "$opencode_mcp_json" '. + { mcp: $mcp }')"
  opencode_expected_json="$(printf '%s' "$opencode_expected_json" | jq '.')"
  ensure_text_file "$opencode_config_file" "$opencode_expected_json"

  local claude_mcp_expected_json
  claude_mcp_expected_json="$(build_claude_mcp_json "$source_file")"
  claude_mcp_expected_json="$(printf '%s' "$claude_mcp_expected_json" | jq '.')"
  ensure_text_file "$claude_project_mcp_file" "$claude_mcp_expected_json"
}

if (( $# > 1 )); then
  usage
  exit 1
fi

if (( $# == 1 )); then
  if [[ "$1" == "--check" ]]; then
    check_only=1
  else
    usage
    exit 1
  fi
fi

require_cmd yq
require_cmd jq

if ! yq --version 2>/dev/null | grep -qi 'mikefarah'; then
  fail "yq must be the mikefarah/yq binary"
fi

home="$HOME"
ai_root="$home/.config/ai"
source_agents_dir="$ai_root/agents"
source_mcp_file="$ai_root/mcp/servers.json"

dotfiles_root=""
script_realpath="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || true)"
if [[ -n "$script_realpath" ]]; then
  dotfiles_root="$(cd "$(dirname "$script_realpath")/../.." >/dev/null 2>&1 && pwd -P || true)"
fi
if [[ -z "$dotfiles_root" ]]; then
  dotfiles_root="$home/dotfiles"
fi

opencode_agents_dir="$home/.config/opencode/agents"
claude_agents_dir="$home/.claude/agents"
opencode_config_file="$home/.config/opencode/opencode.json"
claude_project_mcp_file="$dotfiles_root/.mcp.json"

changed=0

ensure_symlink "$home/.config/opencode/AGENTS.md" "$ai_root/AGENTS.md"
ensure_symlink "$home/.config/opencode/skills" "$ai_root/skills"
ensure_symlink "$home/.claude/skills" "$ai_root/skills"
ensure_symlink "$home/.claude/plugins/local/skills" "$ai_root/skills"
ensure_text_file "$home/.claude/CLAUDE.md" "@~/.config/ai/AGENTS.md"
sync_mcp_configs "$source_mcp_file" "$opencode_config_file" "$claude_project_mcp_file"

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

expected_claude_dir="$tmp_dir/claude"
expected_opencode_dir="$tmp_dir/opencode"
mkdir -p "$expected_claude_dir" "$expected_opencode_dir"

if [[ -d "$source_agents_dir" ]]; then
  shopt -s nullglob
  source_files=("$source_agents_dir"/*.md)

  for source_file in "${source_files[@]}"; do
    base_name="$(basename "$source_file")"
    lower_name="$(printf '%s' "$base_name" | tr '[:upper:]' '[:lower:]')"
    if [[ "$lower_name" == "readme.md" ]]; then
      continue
    fi

    frontmatter_file="$tmp_dir/frontmatter.yaml"
    body_file="$tmp_dir/body.md"
    normalized_body_file="$tmp_dir/body.normalized.md"

    : > "$frontmatter_file"
    : > "$body_file"

    if ! extract_markdown_parts "$source_file" "$frontmatter_file" "$body_file"; then
      fail "$source_file: missing YAML frontmatter delimited by ---"
    fi

    name_value="$(yq eval -r '.name // ""' "$frontmatter_file")"
    description_value="$(yq eval -r '.description // ""' "$frontmatter_file")"

    [[ -n "$name_value" ]] || fail "$source_file: missing required frontmatter key 'name'"
    [[ -n "$description_value" ]] || fail "$source_file: missing required frontmatter key 'description'"

    source_json_file="$tmp_dir/source.json"
    yq eval -o=json '.' "$frontmatter_file" > "$source_json_file"

    claude_json_file="$tmp_dir/claude.json"
    opencode_json_file="$tmp_dir/opencode.json"

    build_claude_json "$source_json_file" > "$claude_json_file"
    build_opencode_json "$source_json_file" > "$opencode_json_file"

    claude_yaml_file="$tmp_dir/claude.yaml"
    opencode_yaml_file="$tmp_dir/opencode.yaml"

    yq eval -P -oy '.' "$claude_json_file" > "$claude_yaml_file"
    yq eval -P -oy '.' "$opencode_json_file" > "$opencode_yaml_file"

    normalize_body "$body_file" "$normalized_body_file"

    render_agent_file "$claude_yaml_file" "$normalized_body_file" "$expected_claude_dir/$base_name"
    render_agent_file "$opencode_yaml_file" "$normalized_body_file" "$expected_opencode_dir/$base_name"
  done

  shopt -u nullglob
fi

sync_directory "$claude_agents_dir" "$expected_claude_dir"
sync_directory "$opencode_agents_dir" "$expected_opencode_dir"

if (( check_only )) && (( changed )); then
  fail "configuration drift detected"
fi

exit 0

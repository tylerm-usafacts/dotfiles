      "installer": {
        "macos": {
          "type": "native",
          "detect": "test -d \"$HOME/.local/share/claude/versions\"",
          "install": "curl -fsSL https://claude.ai/install.sh | bash"
        },
        "linux": {
          "type": "native",
          "detect": "test -d \"$HOME/.local/share/claude/versions\"",
          "install": "curl -fsSL https://claude.ai/install.sh | bash"
        }
      }
    },
    {
      "name": "opencode",
      "installer": {
        "macos": {
          "type": "native",
          "detect": "test -x \"$HOME/.opencode/bin/opencode\"",
          "install": "curl -fsSL https://opencode.ai/install | bash"
        },
        "linux": {
          "type": "native",
          "detect": "test -x \"$HOME/.opencode/bin/opencode\"",
          "install": "curl -fsSL https://opencode.ai/install | bash"
        }
      }

{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-20250805",
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "tools": {
    "atlassian_*": false
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "uv *": "allow",
      "poetry *": "allow",
      "pip *": "allow",
      "python *": "allow",
      "pytest *": "allow",
      "npm run *": "allow",
      "bun *": "allow",
      "sync-ai-config": "allow",
      "sync-ai-config --check": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "rm -rf *": "deny",
      "git push --force *": "deny"
    }
  },
  "instructions": [
    "~/.config/ai/AGENTS.md"
  ]
}
